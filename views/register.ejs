<html lang="en">
<%- include("./partials/head.ejs") %>

  <body>
    <main class="container">
      <div class="form-box">
        <form class="form" action="/register" method="post">
          <label for="username">Username</label>
          <input type="text" id="username" value="<%= username %>" name="username">
          <label for="password">Password:</label>
          <input type="password" id="password" value="<%= password %>" name="password">
          <label for="confirmPassword">Confirm password:</label>
          <input type="password" id="confirmPassword" value="<%= confirmPassword %>" name="confirmPassword">
          <%- include('./partials/errors.ejs', {errors: errors})%>
            <div class="flex-center">
              <button type="submit">Submit</button>
            </div>
        </form>
        <h3> Already have an account yet? <a href="/login" class="link">Sign in</a></h3>
      </div>
    </main>
  </body>

</html>