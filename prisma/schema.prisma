generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  files     File[]
  folders   Folder[]
}

model Folder {
  id         Int      @id @default(autoincrement())
  folderName String
  createdAt  DateTime @default(now())
  userId     Int
  files      File[]
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model File {
  id        Int      @id @default(autoincrement())
  fileSize  Int
  fileName  String
  fileType  String
  fileUrl   String
  createdAt DateTime @default(now())
  folderId  Int
  userId    Int
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
